{
  "branches": ["release"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],

    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/gitlab",
      {
        "assets": [
          {
            "path": "build/web-reg-uo-backend.zip",
            "label": "web-reg-uo-backend-${nextRelease.version}.zip",
            "target": "generic_package",
            "packageName": "web-reg-uo-backend-${nextRelease.version}.zip",
            "status": "default"
          }
        ]
      }
    ]
  ],
  "repositoryUrl": "http://reshenie-soft.ru:7027/web/web-reg-uo/backend.git"
}
