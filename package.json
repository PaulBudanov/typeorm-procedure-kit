{
  "name": "typeorm-procedure-kit",
  "version": "1.0.0",
  "description": "TypeScript toolkit for TypeORM-based Oracle and PostgreSQL apps: stored procedure calls, raw SQL transactions, database notifications, serializers, and a bundled typed TypeORM 0.3.28 fork",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./nestjs": {
      "types": "./dist/types/nest/index.d.ts",
      "import": "./dist/esm/nest/index.js",
      "require": "./dist/cjs/nest/index.js",
      "default": "./dist/esm/nest/index.js"
    },
    "./typeorm": {
      "types": "./dist/types/typeorm/index.d.ts",
      "import": "./dist/esm/typeorm/index.js",
      "require": "./dist/cjs/typeorm/index.js",
      "default": "./dist/esm/typeorm/index.js"
    },
    "./typeorm-extend": {
      "types": "./dist/types/typeorm-extend/index.d.ts",
      "import": "./dist/esm/typeorm-extend/index.js",
      "require": "./dist/cjs/typeorm-extend/index.js",
      "default": "./dist/esm/typeorm-extend/index.js"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js",
      "default": "./dist/esm/*.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "docs",
    "CHANGELOG.md"
  ],
  "scripts": {
    "semantic-release": "semantic-release",
    "build": "npm run clean && npm run lint && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "clean": "rm -rf dist",
    "check": "npm run typecheck && npm run typecheck:test && npm run lint && npm run test",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=reports/vitest/junit.xml",
    "test:watch": "vitest",
    "check:ci": "npm run typecheck && npm run typecheck:test && npm run lint && npm run test:ci",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "typeorm",
    "typeorm-fork",
    "typeorm-0.3",
    "typescript",
    "orm",
    "postgresql",
    "postgres",
    "pg",
    "oracle",
    "oracledb",
    "stored-procedures",
    "procedure-call",
    "plsql",
    "raw-sql",
    "sql-transactions",
    "database-notifications",
    "listen-notify",
    "oracle-cqn",
    "continuous-query-notification",
    "refcursor",
    "entity-metadata",
    "query-runner",
    "data-source",
    "serializers",
    "nestjs",
    "type-safe"
  ],
  "author": "Paul Budanov",
  "license": "MIT",
  "homepage": "https://github.com/PaulBudanov/typeorm-procedure-kit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaulBudanov/typeorm-procedure-kit.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/PaulBudanov/typeorm-procedure-kit/issues"
  },
  "dependencies": {
    "@sqltools/formatter": "^1.2.5",
    "ansis": "^4.2.0",
    "app-root-path": "^3.1.0",
    "dedent": "^1.7.1",
    "dotenv": "^17.3.1",
    "glob": "^13.0.3",
    "lodash-es": "^4.17.23",
    "lru-cache": "^11.2.7",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.2.2",
    "sql-highlight": "^6.1.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "pg": "^8.5.1",
    "@types/pg": "^8.0.0",
    "pg-query-stream": "^4.12.0",
    "oracledb": "^6.0.0",
    "@types/oracledb": "^6.9.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@types/pg": {
      "optional": true
    },
    "pg-query-stream": {
      "optional": true
    },
    "oracledb": {
      "optional": true
    },
    "@types/oracledb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.2.0",
    "@types/oracledb": "^6.10.1",
    "@types/pg": "^8.16.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "madge": "^8.0.0",
    "oracledb": "^6.10.0",
    "pg": "^8.17.2",
    "pg-query-stream": "^4.12.0",
    "semantic-release": "^25.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "sideEffects": [
    "./dist/cjs/index.js",
    "./dist/cjs/typeorm/index.js",
    "./dist/esm/index.js",
    "./dist/esm/typeorm/index.js"
  ]
}
