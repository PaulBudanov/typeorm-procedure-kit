{
  "name": "@web-mis/typeorm-procedure-kit",
  "version": "1.3.7",
  "description": "Universal adapter for executing stored procedures and managing database notifications across Oracle and PostgreSQL with TypeORM integration",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./nestjs": {
      "types": "./dist/types/nest/index.d.ts",
      "import": "./dist/esm/nest/index.js",
      "require": "./dist/cjs/nest/index.js",
      "default": "./dist/esm/nest/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "semantic-release": "semantic-release",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "npm i && npm run lint && tsc -p tsconfig.esm.json",
    "build:cjs": "npm i && npm run lint && tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "keywords": [
    "typeorm",
    "stored-procedures",
    "database",
    "oracle",
    "postgresql",
    "postgres",
    "database-adapter",
    "typescript",
    "cqn",
    "continuous-query-notification",
    "database-notifications",
    "procedure-adapter",
    "multi-database",
    "enterprise",
    "nest",
    "nestjs",
    "orm",
    "sql",
    "transaction",
    "connection-pooling",
    "data-serialization",
    "camelcase",
    "type-safe",
    "database-connector"
  ],
  "author": "Paul Budanov",
  "license": "MIT",
  "bugs": {
    "url": "http://reshenie-soft.ru:7027/web-mis/packages/typeorm-procedure-kit/issues",
    "email": "budanov@reshenie-soft.ru"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@types/oracledb": "^6.0.0",
    "@types/pg": "^8.0.0",
    "@web-mis/queue-manager": "^1.0.9",
    "lodash-es": "^4.0.0",
    "lru-cache": "^11.0.0",
    "luxon": "^3.0.0",
    "oracledb": "^6.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.2.0",
    "typeorm": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "oracledb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.9",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.2.0",
    "@types/oracledb": "^6.10.1",
    "@types/pg": "^8.16.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "oracledb": "^6.10.0",
    "pg": "^8.17.2",
    "semantic-release": "^25.0.2",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "sideEffects": false
}
